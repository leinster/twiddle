{
  "name": "leinster/twiddle",
  "description": "Generates k-combinations. A PHP implementation of Chase's TWIDDLE, https://dl.acm.org/doi/10.1145/362384.362502, transliterated from Matthew Belmonte's C implementation.",
  "keywords": ["combinations", "k-combinations", "combinatorics"],
  "readme": "README.org",
  "license": ["Apache-2.0"],
  "autoload": {
    "psr-4": { "Leinster\\Twiddle\\": "src/" },
    "files": ["src/functions.php"]
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1",
    "symfony/var-dumper": "^6.2",
    "rector/rector": "^2.0",
    "symplify/easy-coding-standard": "^12.5"
  },
  "require": {
    "php": "^8.2",
    "markrogoyski/math-php": "^2.10"
  },
  "scripts": {
    "lint": "ecs check",
    "lint:fix": "ecs check --fix",
    "rector": "rector process --dry-run",
    "rector:fix": "rector process",
    "phpstan": "phpstan analyse --level 9 src tests",
    "test": "phpunit tests",
    "all": ["@lint", "@rector", "@phpstan", "@test"]
  },
  "authors": [
    { "name": "Jonathon Ramsey", "email": "jonathon.ramsey@gmail.com" }
  ]
}
